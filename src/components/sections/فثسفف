const BlocksRender = ({ blocks, serviceId = "", serviceTitle = "" }) => {
  return (
    <>
      {blocks.map((block) => {
        return (
          <div key={block.id}>
            {/* 'بانر الرئيسيه العظيم', 'main_hero_banner' */}
